#!/usr/bin/env bash
set -euo pipefail

SERAF_HOME="/opt/seraf"
SERAF_VENV="${SERAF_HOME}/venv"
SERAF_APP="${SERAF_HOME}/app"

export SERAF_HOME
export SERAF_CONFIG_DIR="${SERAF_CONFIG_DIR:-/etc/seraf}"
export SERAF_STATE_DIR="${SERAF_STATE_DIR:-/var/lib/seraf}"

cd "${PWD}"
exec "${SERAF_VENV}/bin/python" -m seraf.cli "$@"
