#!/usr/bin/env bash
set -euo pipefail

LOCAL26_HOME="${LOCAL26_HOME:-/opt/local26}"
LOCAL26_VENV="${LOCAL26_VENV:-${LOCAL26_HOME}/venv}"

export LOCAL26_HOME
export LOCAL26_CONFIG_DIR="${LOCAL26_CONFIG_DIR:-/etc/local26}"
export LOCAL26_STATE_DIR="${LOCAL26_STATE_DIR:-/var/lib/local26}"

if [ ! -x "${LOCAL26_VENV}/bin/python" ]; then
  printf 'local26: packaged Python runtime not found at %s\n' "${LOCAL26_VENV}" >&2
  exit 127
fi

exec "${LOCAL26_VENV}/bin/python" -m local26.cli "$@"
