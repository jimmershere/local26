{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jimmershere.github.io/local26/schemas/project-task.schema.json",
  "title": "Local-26 Project Task",
  "description": "Structured bounded work unit for Xander-side execution against a project repo.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "task_type",
    "project",
    "repo_path",
    "objective",
    "tasks",
    "status",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable task identifier, ideally a UUID."
    },
    "task_type": {
      "const": "project_task"
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "repo_path": {
      "type": "string",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "docs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "deliverables": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "stop_condition": {
      "type": "string"
    },
    "summary_required": {
      "type": "boolean",
      "default": true
    },
    "depends_on": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "priority": {
      "type": "string",
      "enum": ["low", "normal", "high"],
      "default": "normal"
    },
    "max_runtime_minutes": {
      "type": "integer",
      "minimum": 1,
      "default": 45
    },
    "allow_partial_summary": {
      "type": "boolean",
      "default": true
    },
    "write_summary_to": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "running", "done", "failed"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "files_changed": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "commands_working": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "tests_passed": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "tests_failed": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "open_questions": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "recommended_next_job": {
          "type": "string",
          "default": ""
        }
      }
    }
  }
}
