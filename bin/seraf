#!/usr/bin/env bash
# Deprecated development/source-tree launcher for the old Seraf command name.
# Use bin/local26 or the installed local26 command instead.

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
python_src="${repo_root}/src"

if ! command -v python3 >/dev/null 2>&1; then
  printf 'local26: python3 is required
' >&2
  exit 127
fi

printf 'seraf: deprecated command name; use local26 instead\n' >&2
PYTHONPATH="${python_src}${PYTHONPATH:+:${PYTHONPATH}}" exec python3 -m local26.cli "$@"
