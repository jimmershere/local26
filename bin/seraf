usage() {
  cat <<'USAGE'
Usage:
  seraf init [--import PATH] [--force] [--project NAME]
  seraf plan
  seraf deploy --plan PATH [--dry-run] [--scope NAME] [--max-parallel N]
  seraf deploy --latest [--dry-run] [--scope NAME] [--max-parallel N]
  seraf pull [--scope NAME] [--hosts CSV] [--rsync-opts OPTS] [--dry-run]
  seraf diag [--project NAME] [--hosts CSV] [--diag-type NAME] [--pid PID]
             [--duration SEC] [--remote-cmd CMD] [--out-dir DIR]
             [--ssh-user USER] [--include-disabled] [--dry-run]
  seraf pull-logs [--settings PATH] [--hosts CSV] [--dest DIR]
                  [--jboss-path PATH] [--apache-path PATH]
                  [--engin-path PATH] [--smartxfr-path PATH]
  seraf help
USAGE
}

err() {
  printf 'seraf: %s\n' "$*" >&2
}

warn() {
  printf 'seraf: warning: %s\n' "$*" >&2
}

is_modern_config_ini() {
  local path="$1"
  grep -Eq '^[[:space:]]*\[seraf\][[:space:]]*$|^[[:space:]]*\[scope[[:space:]]+"[^"]+"\][[:space:]]*$' "$path"
}

list_scopes_from_modern_config() {
  local path="$1"
  awk '
    match($0, /^[[:space:]]*\[scope[[:space:]]+"([^"]+)"\][[:space:]]*$/, m) {
      if (!seen[m[1]]++) print m[1]
    }
  ' "$path"
}

upsert_seraf_project_name() {
  local path="$1"
  local project_name="$2"
  local tmp
  tmp="$(mktemp "$(dirname "$path")/.tmp.project.XXXXXX")"
  awk -v project_name="$project_name" '
    function print_project() {
      print "project = " project_name
    }
    BEGIN {
      in_seraf=0
      inserted=0
      replaced=0
    }
    {
      line=$0

      if (line ~ /^[[:space:]]*\[seraf\][[:space:]]*$/) {
        in_seraf=1
        inserted=0
        replaced=0
        print line
        next
      }

      if (in_seraf && line ~ /^[[:space:]]*\[/) {
        if (!inserted && !replaced) print_project()
        in_seraf=0
      }

      if (in_seraf) {
        if (line ~ /^[[:space:]]*project[[:space:]]*=/) {
          if (!replaced) print_project()
          replaced=1
          inserted=1
          next
        }

        print line

        if (!inserted && line ~ /^[[:space:]]*version[[:space:]]*=/) {
          print_project()
          inserted=1
        }
        next
      }

      print line
    }
    END {
      if (in_seraf && !inserted && !replaced) print_project()
    }
  ' "$path" > "$tmp"
  mv -f "$tmp" "$path"
}

iso8601_utc_from_epoch() {
  local epoch="$1"
  date -u -d "@${epoch}" +"%Y-%m-%dT%H:%M:%SZ"
}

atomic_write() {
  local target="$1"
  local content="$2"
  local dir tmp
  dir="$(dirname "$target")"
  tmp="$(mktemp "${dir}/.tmp.XXXXXX")"
  printf '%s' "$content" > "$tmp"
  mv -f "$tmp" "$target"
}

json_escape() {
  printf '%s' "$1" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g'
}

shell_dquote_escape() {
  printf '%s' "$1" | sed -e 's/[\\$`\"]/\\\\&/g'
}

git_bin() {
  if [ -x /usr/bin/git ]; then
    printf '/usr/bin/git\n'
  else
    command -v git || true
  fi
}

resolve_ref_to_sha() {
  local repo_cache_dir="$1" ref="$2"
  local git_cmd sha
  git_cmd="$(git_bin)"
  [ -n "$git_cmd" ] || { err "required tool missing: git"; return 1; }
  sha="$($git_cmd --git-dir="$repo_cache_dir" rev-parse "${ref}^{commit}")" || return 1
  if ! [[ "$sha" =~ ^[0-9a-f]{40}$ ]]; then
    err "unable to resolve ref '${ref}' to full commit sha"
    return 1
  fi
  printf '%s\n' "$sha"
}

ensure_repo_cache() {
  local repo_url="$1" workspace_root_dir="$2"
  local git_cmd repo_cache_dir
  git_cmd="$(git_bin)"
  [ -n "$git_cmd" ] || { err "required tool missing: git"; return 1; }

  mkdir -p "$workspace_root_dir"
  repo_cache_dir="${workspace_root_dir}/repo.git"
  if [ ! -d "$repo_cache_dir" ]; then
    $git_cmd clone --mirror "$repo_url" "$repo_cache_dir" >/dev/null 2>&1
  fi
  $git_cmd --git-dir="$repo_cache_dir" fetch --prune >/dev/null 2>&1
}

ensure_checkout() {
  local scope="$1" repo_url="$2" ref="$3" sha="$4" workspace_root_dir="$5"
  local git_cmd repo_cache_dir checkout_dir head_sha
  git_cmd="$(git_bin)"
  [ -n "$git_cmd" ] || { err "required tool missing: git"; return 1; }

  ensure_repo_cache "$repo_url" "$workspace_root_dir"
  repo_cache_dir="${workspace_root_dir}/repo.git"

  checkout_dir="${workspace_root_dir}/checkouts/${sha}"
  if [ ! -d "$checkout_dir" ]; then
    mkdir -p "${workspace_root_dir}/checkouts"
    $git_cmd clone "$repo_cache_dir" "$checkout_dir" >/dev/null 2>&1
    $git_cmd -C "$checkout_dir" checkout --detach "$sha" >/dev/null 2>&1
  else
    head_sha="$($git_cmd -C "$checkout_dir" rev-parse HEAD)"
    if [ "$head_sha" != "$sha" ]; then
      $git_cmd -C "$checkout_dir" fetch --all --prune >/dev/null 2>&1
      $git_cmd -C "$checkout_dir" checkout --detach "$sha" >/dev/null 2>&1
    fi
  fi

  printf '%s\n' "$checkout_dir"
}

json_unescape() {
  printf '%s' "$1" | sed -e 's/\\\//\//g' -e 's/\\"/"/g' -e 's/\\\\/\\/g'
}

split_json_objects() {
  local input="$1"
  local i len ch depth=0 in_string=0 escaped=0 obj=""
  len=${#input}
  for ((i = 0; i < len; i++)); do
    ch="${input:i:1}"
    if [ "$in_string" -eq 1 ]; then
      obj+="$ch"
      if [ "$escaped" -eq 1 ]; then
        escaped=0
      elif [ "$ch" = "\\" ]; then
        escaped=1
      elif [ "$ch" = '"' ]; then
        in_string=0
      fi
      continue
    fi

    case "$ch" in
      '"')
        in_string=1
        obj+="$ch"
        ;;
      '{')
        depth=$((depth + 1))
        obj+="$ch"
        ;;
      '}')
        depth=$((depth - 1))
        obj+="$ch"
        if [ "$depth" -eq 0 ]; then
          printf '%s\n' "$obj"
          obj=""
        fi
        ;;
      *)
        if [ "$depth" -gt 0 ]; then
          obj+="$ch"
        fi
        ;;
    esac
  done
}

deploy_command() {
  local plan_path=""
  local use_latest=0
  local dry_run=0
  local only_scope=""
  local max_parallel=4

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --plan)
        [ "$#" -ge 2 ] || { err "--plan requires a path"; return 2; }
        plan_path="$2"
        shift 2
        ;;
      --latest)
        use_latest=1
        shift
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --scope)
        [ "$#" -ge 2 ] || { err "--scope requires a value"; return 2; }
        only_scope="$2"
        shift 2
        ;;
      --max-parallel)
        [ "$#" -ge 2 ] || { err "--max-parallel requires a value"; return 2; }
        max_parallel="$2"
        shift 2
        ;;
      -h|--help)
        usage
        return 0
        ;;
      *)
        err "unknown option: $1"
        return 2
        ;;
    esac
  done

  if { [ -n "$plan_path" ] && [ "$use_latest" -eq 1 ]; } || { [ -z "$plan_path" ] && [ "$use_latest" -eq 0 ]; }; then
    err "must provide exactly one of --plan PATH or --latest"
    return 2
  fi

  if ! [[ "$max_parallel" =~ ^[0-9]+$ ]] || [ "$max_parallel" -lt 1 ]; then
    err "--max-parallel must be a positive integer"
    return 2
  fi

  if [ "$use_latest" -eq 1 ]; then
    plan_path="$(ls -1 .seraf/plans/*.plan.json 2>/dev/null | LC_ALL=C sort | tail -n1 || true)"
    [ -n "$plan_path" ] || { err "no plan files found in .seraf/plans"; return 1; }
  fi

  [ -f "$plan_path" ] || { err "plan not found: $plan_path"; return 1; }
  [ -f .seraf/config.ini ] || { err "missing config: .seraf/config.ini"; return 1; }

  : > .seraf/seraf.lock
  exec 9>>.seraf/seraf.lock
  flock 9

  local tmp_steps tmp_meta tmp_scopes tmp_results
  tmp_steps="$(mktemp .seraf/.deploy_steps.XXXXXX)"
  tmp_meta="$(mktemp .seraf/.deploy_meta.XXXXXX)"
  tmp_scopes="$(mktemp .seraf/.deploy_scopes.XXXXXX)"
  tmp_results="$(mktemp .seraf/.deploy_results.XXXXXX)"
  trap 'rm -f "${tmp_scopes:-}" "${tmp_steps:-}" "${tmp_meta:-}" "${tmp_results:-}"' EXIT INT TERM

  python3 - <<'PY' "$plan_path" "$only_scope" "$tmp_meta" "$tmp_steps" "$tmp_scopes"
import json,sys
plan_path, only_scope, meta_path, steps_path, scopes_path = sys.argv[1:]
with open(plan_path, 'r', encoding='utf-8') as f:
    plan=json.load(f)

scopes=plan.get("scopes", [])
selected=[]
for scope in scopes:
    sname=scope.get("scope", "")
    if only_scope and sname != only_scope:
        continue
    selected.append(scope)

with open(meta_path, 'w', encoding='utf-8') as f:
    f.write(f"kind\t{plan.get('kind','')}\n")
    f.write(f"mode\t{plan.get('mode','')}\n")
    f.write(f"schema\t{plan.get('schema','')}\n")
    f.write(f"seraf_version\t{plan.get('seraf_version','')}\n")
    f.write(f"plan_id\t{plan.get('plan_id','')}\n")
    f.write(f"config_fingerprint\t{plan.get('config_fingerprint','')}\n")
    f.write(f"scope_found\t{1 if (not only_scope or any(s.get('scope') == only_scope for s in scopes)) else 0}\n")
    f.write(f"selected_scopes\t{len(selected)}\n")

with open(scopes_path, 'w', encoding='utf-8') as f:
    for scope in selected:
        f.write(scope.get('scope','') + "\n")

with open(steps_path, 'w', encoding='utf-8') as f:
    for scope in selected:
        sname=scope.get('scope','')
        for step in scope.get('steps', []):
            host=step.get('host','') or step.get('server','')
            row=[sname, step.get('id',''), step.get('type',''), host, step.get('cmd',''), step.get('label','')]
            f.write("\t".join(v.replace("\t", " ").replace("\n", " ") for v in row) + "\n")
PY

  local kind mode schema seraf_version plan_id plan_fingerprint found_scope selected_scopes
  kind="$(awk -F'\t' '$1=="kind"{print $2}' "$tmp_meta")"
  mode="$(awk -F'\t' '$1=="mode"{print $2}' "$tmp_meta")"
  schema="$(awk -F'\t' '$1=="schema"{print $2}' "$tmp_meta")"
  seraf_version="$(awk -F'\t' '$1=="seraf_version"{print $2}' "$tmp_meta")"
  plan_id="$(awk -F'\t' '$1=="plan_id"{print $2}' "$tmp_meta")"
  plan_fingerprint="$(awk -F'\t' '$1=="config_fingerprint"{print $2}' "$tmp_meta")"
  found_scope="$(awk -F'\t' '$1=="scope_found"{print $2}' "$tmp_meta")"
  selected_scopes="$(awk -F'\t' '$1=="selected_scopes"{print $2}' "$tmp_meta")"

  [ "$kind" = "plan" ] || { err "invalid plan header: kind must be 'plan'"; return 1; }
  [ "$mode" = "deploy" ] || { err "invalid plan header: mode must be 'deploy'"; return 1; }
  [ "$schema" = "seraf.plan.v0.1" ] || { err "invalid plan header: schema must be 'seraf.plan.v0.1'"; return 1; }
  [ "$seraf_version" = "0.1" ] || { err "invalid plan header: seraf_version must be '0.1'"; return 1; }

  local actual_fingerprint
  actual_fingerprint="sha256:$(sha256sum .seraf/config.ini | awk '{print $1}')"
  if [ "$actual_fingerprint" != "$plan_fingerprint" ]; then
    err "config fingerprint mismatch: expected ${plan_fingerprint}, got ${actual_fingerprint}"
    return 1
  fi

  mkdir -p .seraf/runs
  local run_id run_dir started_at started_epoch
  started_epoch="$(date -u +%s)"
  started_at="$(iso8601_utc_from_epoch "$started_epoch")"
  run_id="$(date -u +%Y%m%dT%H%M%SZ)-$$"
  run_dir=".seraf/runs/${run_id}"
  mkdir -p "$run_dir"

  local run_log="${run_dir}/run.log"
  : > "$run_log"
  printf 'run_id=%s\nplan_id=%s\ndry_run=%s\n' "$run_id" "$plan_id" "$([ "$dry_run" -eq 1 ] && printf true || printf false)" >> "$run_log"

  if [ -n "$only_scope" ] && [ "$found_scope" -ne 1 ]; then
    err "scope not found in plan: ${only_scope}"
    return 1
  fi

  [ "$selected_scopes" -gt 0 ] || { err "no scopes selected from plan"; return 1; }

  local step_index=0 active_jobs=0 overall_rc=0
  local -a job_pids=() job_result_files=()

  run_one_step() {
    local idx="$1" step_scope="$2" step_id="$3" step_type="$4" step_host="$5" step_cmd="$6" result_file="$7"
    local s_epoch s_at f_epoch f_at rc=0 out_file err_file out_data err_data out_b64 err_b64
    s_epoch="$(date -u +%s)"
    s_at="$(iso8601_utc_from_epoch "$s_epoch")"
    out_file="${run_dir}/step-${idx}.out"
    err_file="${run_dir}/step-${idx}.err"

    if [ "$dry_run" -eq 1 ]; then
      printf 'dry-run: %s\n' "$step_cmd" >> "$run_log"
      : > "$out_file"
      : > "$err_file"
      rc=0
    else
      printf 'run: %s\n' "$step_cmd" >> "$run_log"
      if [ "$step_type" = "remote_cmd" ]; then
        ssh "$step_host" "$step_cmd" >"$out_file" 2>"$err_file" || rc=$?
      else
        bash -lc "$step_cmd" >"$out_file" 2>"$err_file" || rc=$?
      fi
    fi

    f_epoch="$(date -u +%s)"
    f_at="$(iso8601_utc_from_epoch "$f_epoch")"
    out_data="$(head -c 8192 "$out_file")"
    err_data="$(head -c 8192 "$err_file")"
    out_b64="$(printf '%s' "$out_data" | base64 | tr -d '\n')"
    err_b64="$(printf '%s' "$err_data" | base64 | tr -d '\n')"
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$idx" "$step_scope" "$step_id" "$step_type" "$step_host" "$step_cmd" "$s_at" "$f_at" "$rc" "$out_b64" "$err_b64" > "$result_file"
    return "$rc"
  }

  while IFS=$'\t' read -r step_scope step_id step_type step_host step_cmd step_label; do
    [ -n "$step_id" ] || continue
    step_index=$((step_index + 1))
    result_file="${run_dir}/step-${step_index}.result"

    if [ "$step_type" = "mkdir" ] || [ "$step_type" = "remote_cmd" ]; then
      while [ "$active_jobs" -gt 0 ]; do
        local wait_pid wait_file
        wait_pid="${job_pids[0]}"
        wait_file="${job_result_files[0]}"
        wait "$wait_pid" || true
        job_pids=("${job_pids[@]:1}")
        job_result_files=("${job_result_files[@]:1}")
        active_jobs=$((active_jobs - 1))
      done
      run_one_step "$step_index" "$step_scope" "$step_id" "$step_type" "$step_host" "$step_cmd" "$result_file" || {
        [ "$step_type" = "remote_cmd" ] && break
      }
    else
      while [ "$active_jobs" -ge "$max_parallel" ]; do
        local wait_pid
        wait_pid="${job_pids[0]}"
        wait "$wait_pid" || true
        job_pids=("${job_pids[@]:1}")
        job_result_files=("${job_result_files[@]:1}")
        active_jobs=$((active_jobs - 1))
      done
      run_one_step "$step_index" "$step_scope" "$step_id" "$step_type" "$step_host" "$step_cmd" "$result_file" &
      job_pids+=("$!")
      job_result_files+=("$result_file")
      active_jobs=$((active_jobs + 1))
    fi
  done < "$tmp_steps"

  while [ "$active_jobs" -gt 0 ]; do
    wait "${job_pids[0]}" || true
    job_pids=("${job_pids[@]:1}")
    job_result_files=("${job_result_files[@]:1}")
    active_jobs=$((active_jobs - 1))
  done

  local steps_json="" first_step=1 line finished_at rc
  for ((i = 1; i <= step_index; i++)); do
    line="$(cat "${run_dir}/step-${i}.result")"
    IFS=$'\t' read -r _idx step_scope step_id step_type step_host step_cmd s_at f_at step_rc out_b64 err_b64 <<< "$line"
    rc="$step_rc"
    if [ "$rc" -ne 0 ]; then
      overall_rc="$rc"
    fi
    [ "$first_step" -eq 1 ] || steps_json+=","
    first_step=0
    out_part="$(printf '%s' "$out_b64" | base64 -d 2>/dev/null || true)"
    err_part="$(printf '%s' "$err_b64" | base64 -d 2>/dev/null || true)"
    steps_json+="{\"scope\":\"$(json_escape "$step_scope")\",\"id\":\"$(json_escape "$step_id")\",\"type\":\"$(json_escape "$step_type")\",\"host\":\"$(json_escape "$step_host")\",\"cmd\":\"$(json_escape "$step_cmd")\",\"started_at\":\"${s_at}\",\"finished_at\":\"${f_at}\",\"rc\":${rc},\"stdout\":\"$(json_escape "$out_part")\",\"stderr\":\"$(json_escape "$err_part")\"}"
  done

  finished_at="$(iso8601_utc_from_epoch "$(date -u +%s)")"
  run_json="{\"run_id\":\"${run_id}\",\"plan_id\":\"$(json_escape "$plan_id")\",\"started_at\":\"${started_at}\",\"finished_at\":\"${finished_at}\",\"rc\":${overall_rc},\"dry_run\":$([ "$dry_run" -eq 1 ] && printf true || printf false),\"steps\":[${steps_json}]}"
  atomic_write "${run_dir}/run.json" "$run_json"

  if [ "$dry_run" -eq 0 ] && [ "$overall_rc" -eq 0 ]; then
    local state_scope last_success rsync_count state_json
    while IFS= read -r state_scope; do
      [ -n "$state_scope" ] || continue
      rsync_count="$(awk -F'\t' -v s="$state_scope" '$1==s && $3=="rsync" {c++} END {print c+0}' "$tmp_steps")"
      last_success="$(iso8601_utc_from_epoch "$(date -u +%s)")"
      mkdir -p .seraf/state
      state_json="{\"schema\":\"seraf.state.v0.1\",\"scope\":\"$(json_escape "$state_scope")\",\"last_success\":\"${last_success}\",\"last_plan_id\":\"$(json_escape "$plan_id")\",\"last_run_id\":\"${run_id}\",\"files_last_deployed_count\":${rsync_count}}"
      atomic_write ".seraf/state/${state_scope}.json" "$state_json"
    done < "$tmp_scopes"
  fi

  return "$overall_rc"
}

get_setting_value() {
  local path="$1" key="$2"
  awk -F'=' -v key="$key" '
    function trim(s) { gsub(/^[[:space:]]+/, "", s); gsub(/[[:space:]]+$/, "", s); return s }
    /^[[:space:]]*[;#]/ { next }
    /^[[:space:]]*\[/ { next }
    {
      k=trim($1)
      if (tolower(k) != tolower(key)) next
      v=$0
      sub(/^[^=]*=/, "", v)
      print trim(v)
      exit
    }
  ' "$path"
}

resolve_diag_hosts_for_project() {
  local project="$1" hosts_csv="$2" include_disabled="$3"
  local tmp_input tmp_hosts raw_host
  tmp_input="$(mktemp)"
  tmp_hosts="$(mktemp)"
  trap 'rm -f "${tmp_input:-}" "${tmp_hosts:-}"' RETURN

  case "$project" in
    m2-project)
      printf '%s\n' "$DIAG_HOSTS_M2_PROJECT" > "$tmp_input"
      ;;
    *)
      err "unsupported diag project inventory: ${project}"
      return 1
      ;;
  esac

  if [ -z "$hosts_csv" ] || [ "$hosts_csv" = "all" ]; then
    hosts_csv="all"
  fi

  IFS=',' read -r -a hosts_arr <<< "$hosts_csv"
  for raw_host in "${hosts_arr[@]}"; do
    local host token_matched
    host="$(printf '%s' "$raw_host" | sed -E 's/^[[:space:]]+//; s/[[:space:]]+$//')"
    [ -n "$host" ] || continue

    if [ "$host" = "all" ]; then
      awk -v include_disabled="$include_disabled" '
        NF >= 3 {
          disabled=(NF >= 4 && $4=="x") ? 1 : 0
          if (!include_disabled && disabled) next
          print $1
        }
      ' "$tmp_input" >> "$tmp_hosts"
      continue
    fi

    token_matched="$(awk -v token="$host" -v include_disabled="$include_disabled" '
      NF >= 3 {
        disabled=(NF >= 4 && $4=="x") ? 1 : 0
        if (!include_disabled && disabled) next
        if ($1==token || $2==token || $3==token) {
          print $1
          found=1
          exit
        }
      }
      END { if (!found) exit 1 }
    ' "$tmp_input" || true)"

    if [ -z "$token_matched" ]; then
      err "unknown or disabled host token for project ${project}: ${host}"
      return 1
    fi
    printf '%s\n' "$token_matched" >> "$tmp_hosts"
  done

  awk '!seen[$0]++' "$tmp_hosts" | paste -sd',' -
}

diag_remote_command_for_type() {
  local diag_type="$1" pid="$2" duration="$3"
  case "$diag_type" in
    "$DIAG_TYPE_STRACE")
      printf 'timeout %s strace -f -tt -s 256 -p %s' "$duration" "$pid"
      ;;
    "$DIAG_TYPE_PYSPY")
      printf 'timeout %s py-spy dump --pid %s --native --locals' "$duration" "$pid"
      ;;
    "$DIAG_TYPE_AUSTIN")
      printf 'timeout %s austin -Cp %s' "$duration" "$pid"
      ;;
    *)
      err "unsupported diag type: ${diag_type} (supported: ${DIAG_TYPE_STRACE}, ${DIAG_TYPE_PYSPY}, ${DIAG_TYPE_AUSTIN})"
      return 1
      ;;
  esac
}

diag_command() {
  local project_name=""
  local hosts_csv=""
  local diag_type="$DIAG_TYPE_STRACE"
  local pid=""
  local duration="20s"
  local remote_cmd=""
  local out_dir=""
  local ssh_user=""
  local include_disabled=0
  local dry_run=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --project)
        [ "$#" -ge 2 ] || { err "--project requires a value"; return 2; }
        project_name="$2"
        shift 2
        ;;
      --hosts)
        [ "$#" -ge 2 ] || { err "--hosts requires a CSV value"; return 2; }
        hosts_csv="$2"
        shift 2
        ;;
      --diag-type)
        [ "$#" -ge 2 ] || { err "--diag-type requires a value"; return 2; }
        diag_type="$2"
        shift 2
        ;;
      --pid)
        [ "$#" -ge 2 ] || { err "--pid requires a value"; return 2; }
        pid="$2"
        shift 2
        ;;
      --duration)
        [ "$#" -ge 2 ] || { err "--duration requires a value"; return 2; }
        duration="$2"
        shift 2
        ;;
      --remote-cmd)
        [ "$#" -ge 2 ] || { err "--remote-cmd requires a value"; return 2; }
        remote_cmd="$2"
        shift 2
        ;;
      --out-dir)
        [ "$#" -ge 2 ] || { err "--out-dir requires a value"; return 2; }
        out_dir="$2"
        shift 2
        ;;
      --ssh-user)
        [ "$#" -ge 2 ] || { err "--ssh-user requires a value"; return 2; }
        ssh_user="$2"
        shift 2
        ;;
      --include-disabled)
        include_disabled=1
        shift
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      -h|--help)
        usage
        return 0
        ;;
      *)
        err "unknown option: $1"
        return 2
        ;;
    esac
  done

  if [ -n "$remote_cmd" ] && [ -n "$pid" ]; then
    err "use either --remote-cmd or --pid/--diag-type, not both"
    return 2
  fi

  if [ -z "$remote_cmd" ]; then
    [ -n "$pid" ] || { err "--pid is required unless --remote-cmd is provided"; return 2; }
    remote_cmd="$(diag_remote_command_for_type "$diag_type" "$pid" "$duration")" || return 1
  fi

  if [ -n "$project_name" ]; then
    hosts_csv="$(resolve_diag_hosts_for_project "$project_name" "$hosts_csv" "$include_disabled")" || return 1
  fi
  [ -n "$hosts_csv" ] || { err "no hosts provided; use --hosts CSV or --project NAME"; return 2; }

  [ -n "$out_dir" ] || out_dir=".seraf/diag/$(date -u +%Y%m%dT%H%M%SZ)-$$"
  mkdir -p "$out_dir"

  local run_manifest="${out_dir}/diag-run.tsv"
  : > "$run_manifest"
  printf 'host\trc\tstdout\tstderr\tcmd\n' >> "$run_manifest"

  local overall_rc=0 host raw_host ssh_target rc host_stdout host_stderr
  IFS=',' read -r -a hosts_arr <<< "$hosts_csv"
  for raw_host in "${hosts_arr[@]}"; do
    host="$(printf '%s' "$raw_host" | sed -E 's/^[[:space:]]+//; s/[[:space:]]+$//')"
    [ -n "$host" ] || continue
    ssh_target="$host"
    if [ -n "$ssh_user" ]; then
      ssh_target="${ssh_user}@${host}"
    fi

    host_stdout="${out_dir}/${host}.stdout.log"
    host_stderr="${out_dir}/${host}.stderr.log"
    rc=0
    if [ "$dry_run" -eq 1 ]; then
      printf 'dry-run ssh %s %s\n' "$ssh_target" "$remote_cmd" > "$host_stdout"
      : > "$host_stderr"
    else
      ssh "$ssh_target" "$remote_cmd" >"$host_stdout" 2>"$host_stderr" || rc=$?
      if [ "$rc" -ne 0 ]; then
        overall_rc="$rc"
      fi
    fi
    printf '%s\t%s\t%s\t%s\t%s\n' "$host" "$rc" "$host_stdout" "$host_stderr" "$remote_cmd" >> "$run_manifest"
    printf '[diag] host=%s rc=%s stdout=%s stderr=%s\n' "$host" "$rc" "$host_stdout" "$host_stderr"
  done

  printf '[diag] manifest=%s\n' "$run_manifest"
  return "$overall_rc"
}

pull_logs_command() {
  local settings_path="./settings.cfg"
  local hosts_csv=""
  local dest_dir=""
  local jboss_path=""
  local apache_path=""
  local engin_path=""
  local smartxfr_path=""

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --settings)
        [ "$#" -ge 2 ] || { err "--settings requires a path"; return 2; }
        settings_path="$2"
        shift 2
        ;;
      --hosts)
        [ "$#" -ge 2 ] || { err "--hosts requires a CSV value"; return 2; }
        hosts_csv="$2"
        shift 2
        ;;
      --dest)
        [ "$#" -ge 2 ] || { err "--dest requires a path"; return 2; }
        dest_dir="$2"
        shift 2
        ;;
      --jboss-path)
        [ "$#" -ge 2 ] || { err "--jboss-path requires a path"; return 2; }
        jboss_path="$2"
        shift 2
        ;;
      --apache-path)
        [ "$#" -ge 2 ] || { err "--apache-path requires a path"; return 2; }
        apache_path="$2"
        shift 2
        ;;
      --engin-path)
        [ "$#" -ge 2 ] || { err "--engin-path requires a path"; return 2; }
        engin_path="$2"
        shift 2
        ;;
      --smartxfr-path)
        [ "$#" -ge 2 ] || { err "--smartxfr-path requires a path"; return 2; }
        smartxfr_path="$2"
        shift 2
        ;;
      -h|--help)
        usage
        return 0
        ;;
      *)
        err "unknown option: $1"
        return 2
        ;;
    esac
  done

  if [ -f "$settings_path" ]; then
    [ -n "$hosts_csv" ] || hosts_csv="$(get_setting_value "$settings_path" "log_hosts")"
    [ -n "$dest_dir" ] || dest_dir="$(get_setting_value "$settings_path" "log_dest_dir")"
    [ -n "$jboss_path" ] || jboss_path="$(get_setting_value "$settings_path" "jboss_log_path")"
    [ -n "$apache_path" ] || apache_path="$(get_setting_value "$settings_path" "apache_log_path")"
    [ -n "$engin_path" ] || engin_path="$(get_setting_value "$settings_path" "engin_log_path")"
    [ -n "$smartxfr_path" ] || smartxfr_path="$(get_setting_value "$settings_path" "smartxfr_log_path")"
  fi

  [ -n "$hosts_csv" ] || { err "no log hosts configured; set log_hosts in settings.cfg or pass --hosts"; return 1; }
  [ -n "$dest_dir" ] || dest_dir=".seraf/pulled-logs"

  if [ -z "$jboss_path" ] && [ -z "$apache_path" ] && [ -z "$engin_path" ] && [ -z "$smartxfr_path" ]; then
    err "no log paths configured; define jboss/apache/engin/smartxfr paths in settings.cfg or on command line"
    return 1
  fi

  mkdir -p "$dest_dir"

  local copied_count=0 failed_count=0 host raw_host
  IFS=',' read -r -a hosts_arr <<< "$hosts_csv"
  for raw_host in "${hosts_arr[@]}"; do
    host="$(printf '%s' "$raw_host" | sed -E 's/^[[:space:]]+//; s/[[:space:]]+$//')"
    [ -n "$host" ] || continue
    local host_dir="${dest_dir%/}/${host}"
    mkdir -p "$host_dir"

    pull_component_logs() {
      local component="$1" remote_path="$2"
      [ -n "$remote_path" ] || return 0
      local component_dir
      component_dir="${host_dir}/${component}"
      mkdir -p "$component_dir"
      if scp -q -r "${host}:${remote_path}" "$component_dir/" 2>"${component_dir}/.pull.err"; then
        rm -f "${component_dir}/.pull.err"
        copied_count=$((copied_count + 1))
      else
        warn "failed to pull ${component} logs from ${host}:${remote_path}"
        failed_count=$((failed_count + 1))
      fi
    }

    pull_component_logs "jboss" "$jboss_path"
    pull_component_logs "apache" "$apache_path"
    pull_component_logs "engin" "$engin_path"
    pull_component_logs "smartxfr" "$smartxfr_path"
  done

  printf 'Pulled logs to %s (success=%d, failed=%d)\n' "$dest_dir" "$copied_count" "$failed_count"
  [ "$failed_count" -eq 0 ]
}

pull_command() {
  local config_file=".seraf/config.ini"
  local only_scope=""
  local hosts_override=""
  local rsync_opts="-az"
  local dry_run=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --scope)
        [ "$#" -ge 2 ] || { err "--scope requires a value"; return 2; }
        only_scope="$2"
        shift 2
        ;;
      --hosts)
        [ "$#" -ge 2 ] || { err "--hosts requires a CSV value"; return 2; }
        hosts_override="$2"
        shift 2
        ;;
      --rsync-opts)
        [ "$#" -ge 2 ] || { err "--rsync-opts requires a value"; return 2; }
        rsync_opts="$2"
        shift 2
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      -h|--help)
        usage
        return 0
        ;;
      *)
        err "unknown option: $1"
        return 2
        ;;
    esac
  done

  [ -f "$config_file" ] || { err "missing config: ${config_file}"; return 1; }

  local tmp_scope_kv scope_list_file
  tmp_scope_kv="$(mktemp .seraf/.scope_kv.pull.XXXXXX)"
  scope_list_file="$(mktemp .seraf/.scope_list.pull.XXXXXX)"
  trap 'rm -f "${tmp_scope_kv:-}" "${scope_list_file:-}"' RETURN

  awk -v out="$tmp_scope_kv" '
    function trim(s) { gsub(/^[[:space:]]+/, "", s); gsub(/[[:space:]]+$/, "", s); return s }
    BEGIN { section=""; scope="" }
    {
      line=$0
      sub(/\r$/, "", line)
      if (line ~ /^[ \t]*$/) next
      if (line ~ /^[ \t]*[;#]/) next
      if (match(line, /^[ \t]*\[scope "([^"]+)"\][ \t]*$/, m)) {
        section="scope"
        scope=m[1]
        print scope >> out
        next
      }
      if (line ~ /^[ \t]*\[/) {
        section=""
        scope=""
        next
      }
      if (section != "scope") next
      if (match(line, /^[ \t]*([^=]+)[ \t]*=[ \t]*(.*)$/, m)) {
        key=trim(m[1])
        value=trim(m[2])
        printf("%s\t%s\t%s\n", scope, key, value) >> out
      }
    }
  ' "$config_file"

  awk -F'\t' 'NF==1 && !seen[$1]++ {print $1}' "$tmp_scope_kv" > "$scope_list_file"

  local success_count=0 failed_count=0 matched_scopes=0
  local scope enabled source_dir target_dir servers_csv effective_hosts_csv raw_host host
  while IFS= read -r scope; do
    [ -n "$scope" ] || continue
    if [ -n "$only_scope" ] && [ "$scope" != "$only_scope" ]; then
      continue
    fi
    matched_scopes=$((matched_scopes + 1))

    enabled="$(awk -F'\t' -v s="$scope" '$1==s && $2=="enabled" {print $3; exit}' "$tmp_scope_kv")"
    [ -n "$enabled" ] || enabled="true"
    if [ "$enabled" != "true" ]; then
      printf '[pull] scope=%s skipped (disabled)\n' "$scope"
      continue
    fi

    source_dir="$(awk -F'\t' -v s="$scope" '$1==s && $2=="source_dir" {print $3; exit}' "$tmp_scope_kv")"
    target_dir="$(awk -F'\t' -v s="$scope" '$1==s && $2=="target_dir" {print $3; exit}' "$tmp_scope_kv")"
    servers_csv="$(awk -F'\t' -v s="$scope" '$1==s && $2=="servers" {print $3; exit}' "$tmp_scope_kv")"
    effective_hosts_csv="${hosts_override:-$servers_csv}"

    if [ -z "$source_dir" ] || [ -z "$target_dir" ] || [ -z "$effective_hosts_csv" ]; then
      warn "scope=${scope} skipped (needs source_dir, target_dir, and servers/--hosts)"
      continue
    fi

    mkdir -p "$source_dir"

    IFS=',' read -r -a hosts_arr <<< "$effective_hosts_csv"
    for raw_host in "${hosts_arr[@]}"; do
      host="$(printf '%s' "$raw_host" | sed -E 's/^[[:space:]]+//; s/[[:space:]]+$//')"
      [ -n "$host" ] || continue
      local cmd
      cmd="rsync ${rsync_opts} -- \"${host}:${target_dir%/}/\" \"${source_dir%/}/\""
      if [ "$dry_run" -eq 1 ]; then
        printf '[pull] dry-run scope=%s host=%s cmd=%s\n' "$scope" "$host" "$cmd"
        success_count=$((success_count + 1))
      elif eval "$cmd"; then
        printf '[pull] scope=%s host=%s ok\n' "$scope" "$host"
        success_count=$((success_count + 1))
      else
        warn "scope=${scope} host=${host} failed"
        failed_count=$((failed_count + 1))
      fi
    done
  done < "$scope_list_file"

  if [ "$matched_scopes" -eq 0 ]; then
    err "no matching scopes found"
    return 1
  fi

  printf 'Pulled files into local source dirs (success=%d, failed=%d)\n' "$success_count" "$failed_count"
  [ "$failed_count" -eq 0 ]
}

init_command() {
  local import_path=""
  local force=0
  local project_name=""
  local project_overridden=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --import)
        [ "$#" -ge 2 ] || { err "--import requires a path"; return 2; }
        import_path="$2"
        shift 2
        ;;
      --force)
        force=1
        shift
        ;;
      --project)
        [ "$#" -ge 2 ] || { err "--project requires a name"; return 2; }
        project_name="$2"
        project_overridden=1
        shift 2
        ;;
      -h|--help)
        usage
        return 0
        ;;
      *)
        err "unknown option: $1"
        usage >&2
        return 2
        ;;
    esac
  done

  if [ -z "$project_name" ]; then
    project_name="$(basename "$(pwd)")"
  fi

  mkdir -p .seraf/state .seraf/plans .seraf/runs .seraf/logs
  : > .seraf/seraf.lock

  exec 9>>.seraf/seraf.lock
  flock 9

  if [ -f .seraf/config.ini ] && [ "$force" -ne 1 ]; then
    err ".seraf/config.ini already exists; rerun with --force to overwrite"
    return 1
  fi

  local tmp_kv tmp_scopes scope_list_file
  tmp_kv="$(mktemp .seraf/.legacy_kv.XXXXXX)"
  tmp_scopes="$(mktemp .seraf/.legacy_scopes.XXXXXX)"
  scope_list_file="$(mktemp .seraf/.scope_list.XXXXXX)"

  cleanup_init_temps() {
    rm -f "${tmp_kv:-}" "${tmp_scopes:-}" "${scope_list_file:-}"
  }
  trap cleanup_init_temps EXIT INT TERM

  : > "$tmp_kv"
  : > "$tmp_scopes"
  : > "$scope_list_file"

  if [ -z "$import_path" ]; then
    if [ -f ./settings.cfg ]; then
      import_path="./settings.cfg"
    else
      err "no legacy config provided and ./settings.cfg not found"
      return 1
    fi
  fi

  [ -f "$import_path" ] || { err "legacy config not found: $import_path"; return 1; }

  if is_modern_config_ini "$import_path"; then
    local has_seraf_section has_valid_version has_scope
    has_seraf_section=0
    has_valid_version=0
    has_scope=0

    has_seraf_section="$(awk '
      /^[[:space:]]*\[seraf\][[:space:]]*$/ { found=1 }
      END { print found ? 1 : 0 }
    ' "$import_path")"

    has_valid_version="$(awk -v expected="${SERAF_VERSION}" '
      function trim(s) { gsub(/^[[:space:]]+/, "", s); gsub(/[[:space:]]+$/, "", s); return s }
      /^[[:space:]]*\[seraf\][[:space:]]*$/ { in_seraf=1; next }
      in_seraf && /^[[:space:]]*\[/ { in_seraf=0 }
      in_seraf && match($0, /^[[:space:]]*version[[:space:]]*=[[:space:]]*(.*)$/, m) {
        v=trim(m[1])
        if (v == "0.1" || v == expected) valid=1
      }
      END { print valid ? 1 : 0 }
    ' "$import_path")"

    has_scope="$(awk '
      match($0, /^[[:space:]]*\[scope[[:space:]]+"[^"]+"\][[:space:]]*$/, m) { found=1 }
      END { print found ? 1 : 0 }
    ' "$import_path")"

    if [ "$has_seraf_section" -ne 1 ]; then
      err "modern config import failed: missing [seraf] section"
      return 1
    fi
    if [ "$has_valid_version" -ne 1 ]; then
      err "modern config import failed: [seraf] version must be 0.1 or ${SERAF_VERSION}"
      return 1
    fi
    if [ "$has_scope" -ne 1 ]; then
      err "modern config import failed: missing [scope \"NAME\"] sections"
      return 1
    fi

    cp "$import_path" .seraf/config.ini
    if [ "$project_overridden" -eq 1 ]; then
      upsert_seraf_project_name .seraf/config.ini "$project_name"
    fi

    list_scopes_from_modern_config "$import_path" > "$scope_list_file"

    while IFS= read -r scope; do
      [ -n "$scope" ] || continue
      local last_success="null"
      if [ -f "state/${scope}.last" ]; then
        local epoch
        epoch="$(stat -c %Y "state/${scope}.last")"
        last_success="\"$(iso8601_utc_from_epoch "$epoch")\""
      fi

      local ts
      ts="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
      local state_json
      state_json="{
  \"schema\":\"seraf.state.v0.1\",
  \"scope\":\"${scope}\",
  \"created_at\":\"${ts}\",
  \"last_success\":${last_success},
  \"last_plan_id\":null,
  \"last_run_id\":null,
  \"files_last_deployed_count\":0
}"
      atomic_write ".seraf/state/${scope}.json" "$state_json"
    done < "$scope_list_file"

    printf 'Initialized SERAF .seraf workspace\n'
    return 0
  fi

  awk -v kvout="$tmp_kv" -v scopesout="$tmp_scopes" '
      function trim(s) { gsub(/^[ \t\r\n]+/, "", s); gsub(/[ \t\r\n]+$/, "", s); return s }
      BEGIN { section="" }
      {
        line=$0
        sub(/\r$/, "", line)
        if (line ~ /^[ \t]*$/) next
        if (line ~ /^[ \t]*[;#]/) next
        if (line ~ /^[ \t]*\[/) {
          if (match(line, /^[ \t]*\[([^\]]+)\][ \t]*$/, m)) {
            section=trim(m[1])
            if (section != "" && !seen_scope[section]++) print section >> scopesout
            next
          } else {
            printf("WARN\tinvalid section header\t%d\n", NR) >> kvout
            section=""
            next
          }
        }
        if (section == "") {
          printf("WARN\tkey/value outside section\t%d\n", NR) >> kvout
          next
        }
        if (match(line, /^[ \t]*([^=]+)[ \t]*=[ \t]*(.*)$/, m)) {
          key=tolower(trim(m[1]))
          value=trim(m[2])
          printf("KV\t%s\t%s\t%s\n", section, key, value) >> kvout
        } else {
          printf("WARN\tinvalid key/value\t%d\n", NR) >> kvout
        }
      }
    ' "$import_path"

  awk -F'\t' '$1=="WARN"' "$tmp_kv" | while IFS=$'\t' read -r _ msg line_no; do
    warn "legacy parse warning at line ${line_no}: ${msg}"
  done

  cp "$tmp_scopes" "$scope_list_file"

  if [ ! -s "$scope_list_file" ]; then
    err "no scopes found in legacy config: ${import_path}"
    return 1
  fi

  local unknowns
  unknowns="$(awk -F'\t' '$1=="KV" && $3!="source_dir" && $3!="target_dir" && $3!="servers" && $3!="rsync_opts" && $3!="backup" && $3!="backup_suffix" && $3!="log_hosts" && $3!="log_dest_dir" && $3!="jboss_log_path" && $3!="apache_log_path" && $3!="engin_log_path" && $3!="smartxfr_log_path" {print $3}' "$tmp_kv" | sort -u || true)"
  if [ -n "$unknowns" ]; then
    while IFS= read -r k; do
      [ -n "$k" ] || continue
      warn "ignoring unknown legacy key: ${k}"
    done <<< "$unknowns"
  fi

  local default_scope
  default_scope="$(head -n1 "$scope_list_file")"

  local ssh_path rsync_path find_path
  ssh_path="$(command -v ssh || true)"
  rsync_path="$(command -v rsync || true)"
  find_path="$(command -v find || true)"

  [ -n "$ssh_path" ] || { err "required tool missing: ssh"; return 1; }
  [ -n "$rsync_path" ] || { err "required tool missing: rsync"; return 1; }
  [ -n "$find_path" ] || { err "required tool missing: find"; return 1; }

  local jq_path=""
  if command -v jq >/dev/null 2>&1; then
    jq_path="$(command -v jq)"
  fi

  local config
  config="[seraf]
version = ${SERAF_VERSION}
project = ${project_name}
default_scope = ${default_scope}
state_dir = .seraf/state
plans_dir = .seraf/plans
runs_dir = .seraf/runs
logs_dir = .seraf/logs
lock_file = .seraf/seraf.lock
require_plan_for_deploy = true
fail_fast = true
max_parallel = 4
shell = /usr/bin/bash

[tools]
ssh = ${ssh_path}
rsync = ${rsync_path}
find = ${find_path}"
  if [ -n "$jq_path" ]; then
    config+="
jq = ${jq_path}"
  fi

  config+="

[defaults]
rsync_opts = -az
backup = true
backup_suffix = .bkp
remote_mkdir = true
dry_run_default = false
log_hosts =
log_dest_dir = .seraf/pulled-logs
jboss_log_path =
apache_log_path =
engin_log_path =
smartxfr_log_path =

[routing]
env_from_filename_prefix = s:sys,q:qa,p:production
env_from_server_name_char_at = 4
env_from_server_name_char_map = s:sys,q:qa,p:production"

  local scope
  while IFS= read -r scope; do
    [ -n "$scope" ] || continue
    local source_dir target_dir servers rsync_opts backup backup_suffix
    source_dir="$(awk -F'\t' -v s="$scope" '$1=="KV" && $2==s && $3=="source_dir" {print $4; exit}' "$tmp_kv")"
    target_dir="$(awk -F'\t' -v s="$scope" '$1=="KV" && $2==s && $3=="target_dir" {print $4; exit}' "$tmp_kv")"
    servers="$(awk -F'\t' -v s="$scope" '$1=="KV" && $2==s && $3=="servers" {print $4; exit}' "$tmp_kv")"
    rsync_opts="$(awk -F'\t' -v s="$scope" '$1=="KV" && $2==s && $3=="rsync_opts" {print $4; exit}' "$tmp_kv")"
    backup="$(awk -F'\t' -v s="$scope" '$1=="KV" && $2==s && $3=="backup" {print $4; exit}' "$tmp_kv")"
    backup_suffix="$(awk -F'\t' -v s="$scope" '$1=="KV" && $2==s && $3=="backup_suffix" {print $4; exit}' "$tmp_kv")"

    if [ -z "$source_dir" ] || [ -z "$target_dir" ] || [ -z "$servers" ]; then
      err "legacy section [${scope}] missing required keys (source_dir, target_dir, servers)"
      return 1
    fi

    servers="$(printf '%s' "$servers" | sed -E 's/[[:space:]]*,[[:space:]]*/,/g; s/[[:space:]]+/,/g; s/,+/,/g; s/^,+//; s/,+$//')"

    if [ -n "$backup" ]; then
      local backup_raw backup_normalized
      backup_raw="$backup"
      backup_normalized="$(printf '%s' "$backup" | tr '[:upper:]' '[:lower:]')"
      case "$backup_normalized" in
        true|false)
          backup="$backup_normalized"
          ;;
        *)
          warn "legacy section [${scope}] has invalid backup value '${backup_raw}'; expected true/false, ignoring"
          backup=""
          ;;
      esac
    fi

    config+="

[scope \"${scope}\"]
enabled = true
source_dir = ${source_dir}
target_dir = ${target_dir}
servers = ${servers}
discovery = mtime_since_last_success"
    if [ -n "$rsync_opts" ]; then
      config+="
rsync_opts = ${rsync_opts}"
    fi
    if [ -n "$backup" ]; then
      config+="
backup = ${backup}"
    fi
    if [ -n "$backup_suffix" ]; then
      config+="
backup_suffix = ${backup_suffix}"
    fi
  done < "$scope_list_file"

  atomic_write .seraf/config.ini "$config"

  while IFS= read -r scope; do
    [ -n "$scope" ] || continue
    local last_success="null"
    if [ -f "state/${scope}.last" ]; then
      local epoch
      epoch="$(stat -c %Y "state/${scope}.last")"
      last_success="\"$(iso8601_utc_from_epoch "$epoch")\""
    fi

    local ts
    ts="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
    local state_json
    state_json="{
  \"schema\":\"seraf.state.v0.1\",
  \"scope\":\"${scope}\",
  \"created_at\":\"${ts}\",
  \"last_success\":${last_success},
  \"last_plan_id\":null,
  \"last_run_id\":null,
  \"files_last_deployed_count\":0
}"
    atomic_write ".seraf/state/${scope}.json" "$state_json"
  done < "$scope_list_file"

  printf 'Initialized SERAF .seraf workspace\n'
}

plan_command() {
  local only_scope=""
  local output_format="json"
  local print_stdout=0
  local ci_mode=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --scope)
        [ "$#" -ge 2 ] || { err "--scope requires a value"; return 2; }
        only_scope="$2"
        shift 2
        ;;
      --format)
        [ "$#" -ge 2 ] || { err "--format requires a value"; return 2; }
        output_format="$2"
        shift 2
        ;;
      --stdout)
        print_stdout=1
        shift
        ;;
      --ci)
        ci_mode=1
        shift
        ;;
      -h|--help)
        usage
        return 0
        ;;
      *)
        err "unknown option: $1"
        return 2
        ;;
    esac
  done

  [ "$output_format" = "json" ] || { err "unsupported format: ${output_format}"; return 2; }

  local config_file=".seraf/config.ini"
  local lock_file=".seraf/seraf.lock"

  [ -f "$config_file" ] || { err "missing config: ${config_file}"; return 1; }

  mkdir -p .seraf/plans
  : > "$lock_file"
  exec 9>>"$lock_file"
  flock 9

  local plan_ts config_fingerprint plan_id
  plan_ts="$(date -u +"%Y%m%dT%H%M%SZ")"
  config_fingerprint="$(sha256sum "$config_file" | awk '{print $1}')"
  plan_id="${plan_ts}-${config_fingerprint:0:8}"

  local tmp_scope_kv scope_list_file
  tmp_scope_kv="$(mktemp .seraf/.scope_kv.XXXXXX)"
  scope_list_file="$(mktemp .seraf/.scope_list.XXXXXX)"

  cleanup_plan_temps() {
    rm -f "${tmp_scope_kv:-}" "${scope_list_file:-}" "${tmp_ref:-}" "${tmp_files:-}" "${tmp_all:-}" "${tmp_dirs:-}"
  }
  trap cleanup_plan_temps EXIT INT TERM

  awk -v out="$tmp_scope_kv" '
    function trim(s) { gsub(/^[[:space:]]+/, "", s); gsub(/[[:space:]]+$/, "", s); return s }
    BEGIN { section=""; scope="" }
    {
      line=$0
      sub(/\r$/, "", line)
      if (line ~ /^[ \t]*$/) next
      if (line ~ /^[ \t]*[;#]/) next
      if (match(line, /^[ \t]*\[scope "([^"]+)"\][ \t]*$/, m)) {
        section="scope"
        scope=m[1]
        print scope >> out
        next
      }
      if (line ~ /^[ \t]*\[/) {
        section=""
        scope=""
        next
      }
      if (section != "scope") next
      if (match(line, /^[ \t]*([^=]+)[ \t]*=[ \t]*(.*)$/, m)) {
        key=trim(m[1])
        value=trim(m[2])
        printf("%s\t%s\t%s\n", scope, key, value) >> out
      }
    }
  ' "$config_file"

  awk -F'\t' 'NF==1 && !seen[$1]++ {print $1}' "$tmp_scope_kv" > "$scope_list_file"

  local routing_filename_prefix routing_server_char_at routing_server_char_map
  local default_rsync_opts default_backup default_backup_suffix default_remote_mkdir
  routing_filename_prefix="$(awk '
    function trim(s) { gsub(/^[[:space:]]+/, "", s); gsub(/[[:space:]]+$/, "", s); return s }
    /^[ \t]*\[routing\][ \t]*$/ { insec=1; next }
    /^[ \t]*\[/ { insec=0 }
    insec && $0 ~ /^[ \t]*env_from_filename_prefix[ \t]*=/ { sub(/^[^=]*=/, "", $0); print trim($0); exit }
  ' "$config_file")"
  routing_server_char_at="$(awk '
    function trim(s) { gsub(/^[[:space:]]+/, "", s); gsub(/[[:space:]]+$/, "", s); return s }
    /^[ \t]*\[routing\][ \t]*$/ { insec=1; next }
    /^[ \t]*\[/ { insec=0 }
    insec && $0 ~ /^[ \t]*env_from_server_name_char_at[ \t]*=/ { sub(/^[^=]*=/, "", $0); print trim($0); exit }
  ' "$config_file")"
  routing_server_char_map="$(awk '
    function trim(s) { gsub(/^[[:space:]]+/, "", s); gsub(/[[:space:]]+$/, "", s); return s }
    /^[ \t]*\[routing\][ \t]*$/ { insec=1; next }
    /^[ \t]*\[/ { insec=0 }
    insec && $0 ~ /^[ \t]*env_from_server_name_char_map[ \t]*=/ { sub(/^[^=]*=/, "", $0); print trim($0); exit }
  ' "$config_file")"
  default_rsync_opts="$(awk '
    function trim(s) { gsub(/^[[:space:]]+/, "", s); gsub(/[[:space:]]+$/, "", s); return s }
    /^[ \t]*\[defaults\][ \t]*$/ { insec=1; next }
    /^[ \t]*\[/ { insec=0 }
    insec && $0 ~ /^[ \t]*rsync_opts[ \t]*=/ { sub(/^[^=]*=/, "", $0); print trim($0); exit }
  ' "$config_file")"
  default_backup="$(awk '
    function trim(s) { gsub(/^[[:space:]]+/, "", s); gsub(/[[:space:]]+$/, "", s); return s }
    /^[ \t]*\[defaults\][ \t]*$/ { insec=1; next }
    /^[ \t]*\[/ { insec=0 }
    insec && $0 ~ /^[ \t]*backup[ \t]*=/ { sub(/^[^=]*=/, "", $0); print trim($0); exit }
  ' "$config_file")"
  default_backup_suffix="$(awk '
    function trim(s) { gsub(/^[[:space:]]+/, "", s); gsub(/[[:space:]]+$/, "", s); return s }
    /^[ \t]*\[defaults\][ \t]*$/ { insec=1; next }
    /^[ \t]*\[/ { insec=0 }
    insec && $0 ~ /^[ \t]*backup_suffix[ \t]*=/ { sub(/^[^=]*=/, "", $0); print trim($0); exit }
  ' "$config_file")"
  default_remote_mkdir="$(awk '
    function trim(s) { gsub(/^[[:space:]]+/, "", s); gsub(/[[:space:]]+$/, "", s); return s }
    /^[ \t]*\[defaults\][ \t]*$/ { insec=1; next }
    /^[ \t]*\[/ { insec=0 }
    insec && $0 ~ /^[ \t]*remote_mkdir[ \t]*=/ { sub(/^[^=]*=/, "", $0); print trim($0); exit }
  ' "$config_file")"

  local created_at plan_json
  created_at="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  plan_json="{\"seraf_version\":\"${SERAF_VERSION}\",\"kind\":\"plan\",\"mode\":\"deploy\",\"schema\":\"seraf.plan.v0.1\",\"plan_id\":\"${plan_id}\",\"created_at\":\"${created_at}\",\"config_fingerprint\":\"sha256:${config_fingerprint}\",\"scopes\":["

  local first_scope=1
  local scope
  while IFS= read -r scope; do
    [ -n "$scope" ] || continue
    if [ -n "$only_scope" ] && [ "$scope" != "$only_scope" ]; then
      continue
    fi

    local enabled source_dir target_dir servers_csv discovery rsync_opts backup backup_suffix remote_mkdir
    local workspace workspace_root_dir source_subdir workspace_provider repo_url ref pin
    local deploy_mode stop_cmd start_cmd status_cmd activate_cmd verify_cmd cleanup_cmd
    enabled="$(awk -F'\t' -v s="$scope" '$1==s && $2=="enabled" {print $3; exit}' "$tmp_scope_kv")"
    [ -n "$enabled" ] || enabled="true"
    [ "$enabled" = "true" ] || continue

    source_dir="$(awk -F'\t' -v s="$scope" '$1==s && $2=="source_dir" {print $3; exit}' "$tmp_scope_kv")"
    target_dir="$(awk -F'\t' -v s="$scope" '$1==s && $2=="target_dir" {print $3; exit}' "$tmp_scope_kv")"
    servers_csv="$(awk -F'\t' -v s="$scope" '$1==s && $2=="servers" {print $3; exit}' "$tmp_scope_kv")"
    discovery="$(awk -F'\t' -v s="$scope" '$1==s && $2=="discovery" {print $3; exit}' "$tmp_scope_kv")"
    rsync_opts="$(awk -F'\t' -v s="$scope" '$1==s && $2=="rsync_opts" {print $3; exit}' "$tmp_scope_kv")"
    backup="$(awk -F'\t' -v s="$scope" '$1==s && $2=="backup" {print $3; exit}' "$tmp_scope_kv")"
    backup_suffix="$(awk -F'\t' -v s="$scope" '$1==s && $2=="backup_suffix" {print $3; exit}' "$tmp_scope_kv")"
    remote_mkdir="$(awk -F'\t' -v s="$scope" '$1==s && $2=="remote_mkdir" {print $3; exit}' "$tmp_scope_kv")"
    workspace="$(awk -F'\t' -v s="$scope" '$1==s && $2=="workspace" {print $3; exit}' "$tmp_scope_kv")"
    workspace_root_dir="$(awk -F'\t' -v s="$scope" '$1==s && $2=="workspace_dir" {print $3; exit}' "$tmp_scope_kv")"
    source_subdir="$(awk -F'\t' -v s="$scope" '$1==s && $2=="source_subdir" {print $3; exit}' "$tmp_scope_kv")"
    repo_url="$(awk -F'\t' -v s="$scope" '$1==s && $2=="repo_url" {print $3; exit}' "$tmp_scope_kv")"
    ref="$(awk -F'\t' -v s="$scope" '$1==s && $2=="ref" {print $3; exit}' "$tmp_scope_kv")"
    pin="$(awk -F'\t' -v s="$scope" '$1==s && $2=="pin" {print $3; exit}' "$tmp_scope_kv")"
    deploy_mode="$(awk -F'\t' -v s="$scope" '$1==s && $2=="deploy_mode" {print $3; exit}' "$tmp_scope_kv")"
    stop_cmd="$(awk -F'\t' -v s="$scope" '$1==s && $2=="stop_cmd" {print $3; exit}' "$tmp_scope_kv")"
    start_cmd="$(awk -F'\t' -v s="$scope" '$1==s && $2=="start_cmd" {print $3; exit}' "$tmp_scope_kv")"
    status_cmd="$(awk -F'\t' -v s="$scope" '$1==s && $2=="status_cmd" {print $3; exit}' "$tmp_scope_kv")"
    activate_cmd="$(awk -F'\t' -v s="$scope" '$1==s && $2=="activate_cmd" {print $3; exit}' "$tmp_scope_kv")"
    verify_cmd="$(awk -F'\t' -v s="$scope" '$1==s && $2=="verify_cmd" {print $3; exit}' "$tmp_scope_kv")"
    cleanup_cmd="$(awk -F'\t' -v s="$scope" '$1==s && $2=="cleanup_cmd" {print $3; exit}' "$tmp_scope_kv")"

    [ -n "$rsync_opts" ] || rsync_opts="$default_rsync_opts"
    [ -n "$backup" ] || backup="$default_backup"
    [ -n "$backup_suffix" ] || backup_suffix="$default_backup_suffix"
    [ -n "$remote_mkdir" ] || remote_mkdir="$default_remote_mkdir"

    backup="$(printf '%s' "$backup" | tr '[:upper:]' '[:lower:]')"
    case "$backup" in
      true|false) ;;
      *) backup="false" ;;
    esac

    workspace_provider="source_dir"
    local commit_sha="" resolved_workspace_dir=""
    if [ "$workspace" = "git" ]; then
      [ -n "$repo_url" ] || { err "scope ${scope}: repo_url is required when workspace=git"; return 1; }
      [ -n "$ref" ] || { err "scope ${scope}: ref is required when workspace=git"; return 1; }
      [ -n "$pin" ] || pin="true"
      [ -n "$workspace_root_dir" ] || workspace_root_dir=".seraf/workspaces/${scope}"
      ensure_repo_cache "$repo_url" "$workspace_root_dir"
      commit_sha="$(resolve_ref_to_sha "${workspace_root_dir}/repo.git" "$ref")"
      resolved_workspace_dir="$(ensure_checkout "$scope" "$repo_url" "$ref" "$commit_sha" "$workspace_root_dir")"
      if [ -n "$source_subdir" ]; then
        resolved_workspace_dir="${resolved_workspace_dir%/}/${source_subdir#./}"
      fi
      workspace_provider="git"
      source_dir="$resolved_workspace_dir"
    fi

    [ -n "$source_dir" ] || continue
    [ -n "$target_dir" ] || continue
    [ -n "$servers_csv" ] || continue
    [ "$discovery" = "mtime_since_last_success" ] || continue

    local state_file state_last_success since_json
    state_file=".seraf/state/${scope}.json"
    [ -f "$state_file" ] || { err "missing state: ${state_file}"; return 1; }
    state_last_success="$(sed -n 's/.*"last_success"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$state_file" | head -n1)"
    since_json="null"
    [ -n "$state_last_success" ] && since_json="\"$(json_escape "$state_last_success")\""

    local tmp_ref tmp_files tmp_all
    tmp_ref="$(mktemp .seraf/.ref.XXXXXX)"
    tmp_files="$(mktemp .seraf/.files.XXXXXX)"
    tmp_all="$(mktemp .seraf/.all.XXXXXX)"

    find "$source_dir" -type f -print | LC_ALL=C sort > "$tmp_all"
    local files_found
    files_found="$(wc -l < "$tmp_all" | tr -d ' ')"

    if [ -n "$state_last_success" ]; then
      touch -d "$state_last_success" "$tmp_ref"
      find "$source_dir" -type f -newer "$tmp_ref" -print | LC_ALL=C sort > "$tmp_files"
    else
      cp "$tmp_all" "$tmp_files"
    fi

    local servers_json="" first_server=1 server
    IFS=',' read -r -a servers_arr <<< "$servers_csv"
    for server in "${servers_arr[@]}"; do
      server="$(printf '%s' "$server" | sed -E 's/^[[:space:]]+//; s/[[:space:]]+$//')"
      [ -n "$server" ] || continue
      if [ "$first_server" -eq 1 ]; then
        first_server=0
      else
        servers_json+="," 
      fi
      servers_json+="\"$(json_escape "$server")\""
    done
    servers_json="[${servers_json}]"

    local files_json="" first_file=1 f rel selected_count=0
    while IFS= read -r f; do
      [ -n "$f" ] || continue
      rel="${f#$source_dir/}"
      [ "$f" = "$rel" ] && rel="$(basename "$f")"
      if [ "$first_file" -eq 1 ]; then
        first_file=0
      else
        files_json+="," 
      fi
      files_json+="\"$(json_escape "$rel")\""
      selected_count=$((selected_count + 1))
    done < "$tmp_files"

    local steps_json="" step_n=1 mkdir_steps=0 rsync_steps=0 rollbackable_steps=0
    local should_emit_remote_cmd=0
    if [ "$deploy_mode" = "stage_release" ] || [ -n "$stop_cmd" ] || [ -n "$start_cmd" ] || [ -n "$status_cmd" ]; then
      should_emit_remote_cmd=1
    fi
    for server in "${servers_arr[@]}"; do
      server="$(printf '%s' "$server" | sed -E 's/^[[:space:]]+//; s/[[:space:]]+$//')"
      [ -n "$server" ] || continue

      if [ "$remote_mkdir" = "true" ]; then
        local tmp_dirs
        tmp_dirs="$(mktemp .seraf/.dirs.XXXXXX)"
        while IFS= read -r f; do
          [ -n "$f" ] || continue
          rel="${f#$source_dir/}"
          [ "$f" = "$rel" ] && rel="$(basename "$f")"
          dirname "${target_dir%/}/${rel}"
        done < "$tmp_files" | LC_ALL=C sort -u > "$tmp_dirs"

        while IFS= read -r remote_dir; do
          [ -n "$remote_dir" ] || continue
          local sid cmd server_quoted remote_dir_quoted
          sid="scope:${scope}:$(printf '%04d' "$step_n")"
          server_quoted="$(shell_dquote_escape "$server")"
          remote_dir_quoted="$(shell_dquote_escape "$remote_dir")"
          cmd="ssh \"${server_quoted}\" \"mkdir -p -- \\\"${remote_dir_quoted}\\\"\""
          [ -z "$steps_json" ] || steps_json+="," 
          steps_json+="{\"id\":\"$(json_escape "$sid")\",\"type\":\"mkdir\",\"host\":\"$(json_escape "$server")\",\"cmd\":\"$(json_escape "$cmd")\",\"rollback\":null,\"checks\":{\"requires\":[\"ssh\"]}}"
          step_n=$((step_n + 1))
          mkdir_steps=$((mkdir_steps + 1))
        done < "$tmp_dirs"
        rm -f "$tmp_dirs"
      fi

      if [ "$should_emit_remote_cmd" -eq 1 ] && [ -n "$stop_cmd" ]; then
        sid="scope:${scope}:$(printf '%04d' "$step_n")"
        [ -z "$steps_json" ] || steps_json+="," 
        steps_json+="{\"id\":\"$(json_escape "$sid")\",\"type\":\"remote_cmd\",\"server\":\"$(json_escape "$server")\",\"cmd\":\"$(json_escape "$stop_cmd")\",\"label\":\"stop\",\"checks\":{\"requires\":[\"ssh\"]}}"
        step_n=$((step_n + 1))
      fi
      if [ "$should_emit_remote_cmd" -eq 1 ] && [ -n "$activate_cmd" ]; then
        sid="scope:${scope}:$(printf '%04d' "$step_n")"
        [ -z "$steps_json" ] || steps_json+="," 
        steps_json+="{\"id\":\"$(json_escape "$sid")\",\"type\":\"remote_cmd\",\"server\":\"$(json_escape "$server")\",\"cmd\":\"$(json_escape "$activate_cmd")\",\"label\":\"activate\",\"checks\":{\"requires\":[\"ssh\"]}}"
        step_n=$((step_n + 1))
      fi

      while IFS= read -r f; do
        [ -n "$f" ] || continue
        rel="${f#$source_dir/}"
        [ "$f" = "$rel" ] && rel="$(basename "$f")"
        local local_path remote_path cmd sid rollback_json rollback_cmd remote_backup_quoted remote_path_quoted local_path_quoted remote_target_quoted server_quoted
        local_path="$f"
        remote_path="${target_dir%/}/${rel}"
        cmd="rsync ${rsync_opts}"
        if [ "$backup" = "true" ]; then
          cmd+=" --backup --suffix=$(printf '%q' "$backup_suffix")"
        fi
        local_path_quoted="$(shell_dquote_escape "$local_path")"
        remote_target_quoted="$(shell_dquote_escape "${server}:${remote_path}")"
        cmd+=" -- \"${local_path_quoted}\" \"${remote_target_quoted}\""
        rollback_json="null"
        if [ "$backup" = "true" ]; then
          server_quoted="$(shell_dquote_escape "$server")"
          remote_backup_quoted="$(shell_dquote_escape "${remote_path}${backup_suffix}")"
          remote_path_quoted="$(shell_dquote_escape "$remote_path")"
          rollback_cmd="ssh \"${server_quoted}\" \"cp -a -- \\\"${remote_backup_quoted}\\\" \\\"${remote_path_quoted}\\\"\""
          rollback_json="{\"type\":\"restore\",\"cmd\":\"$(json_escape "$rollback_cmd")\"}"
          rollbackable_steps=$((rollbackable_steps + 1))
        fi
        sid="scope:${scope}:$(printf '%04d' "$step_n")"
        [ -z "$steps_json" ] || steps_json+="," 
        steps_json+="{\"id\":\"$(json_escape "$sid")\",\"type\":\"rsync\",\"host\":\"$(json_escape "$server")\",\"cmd\":\"$(json_escape "$cmd")\",\"local_path\":\"$(json_escape "$local_path")\",\"remote_path\":\"$(json_escape "$remote_path")\",\"rollback\":${rollback_json},\"checks\":{\"requires\":[\"ssh\",\"rsync\"]}}"
        step_n=$((step_n + 1))
        rsync_steps=$((rsync_steps + 1))
      done < "$tmp_files"

      if [ "$should_emit_remote_cmd" -eq 1 ] && [ -n "$start_cmd" ]; then
        sid="scope:${scope}:$(printf '%04d' "$step_n")"
        [ -z "$steps_json" ] || steps_json+="," 
        steps_json+="{\"id\":\"$(json_escape "$sid")\",\"type\":\"remote_cmd\",\"server\":\"$(json_escape "$server")\",\"cmd\":\"$(json_escape "$start_cmd")\",\"label\":\"start\",\"checks\":{\"requires\":[\"ssh\"]}}"
        step_n=$((step_n + 1))
      fi
      if [ "$should_emit_remote_cmd" -eq 1 ] && [ -n "$verify_cmd" ]; then
        sid="scope:${scope}:$(printf '%04d' "$step_n")"
        [ -z "$steps_json" ] || steps_json+="," 
        steps_json+="{\"id\":\"$(json_escape "$sid")\",\"type\":\"remote_cmd\",\"server\":\"$(json_escape "$server")\",\"cmd\":\"$(json_escape "$verify_cmd")\",\"label\":\"verify\",\"checks\":{\"requires\":[\"ssh\"]}}"
        step_n=$((step_n + 1))
      fi
      if [ "$should_emit_remote_cmd" -eq 1 ] && [ -n "$status_cmd" ]; then
        sid="scope:${scope}:$(printf '%04d' "$step_n")"
        [ -z "$steps_json" ] || steps_json+="," 
        steps_json+="{\"id\":\"$(json_escape "$sid")\",\"type\":\"remote_cmd\",\"server\":\"$(json_escape "$server")\",\"cmd\":\"$(json_escape "$status_cmd")\",\"label\":\"status\",\"checks\":{\"requires\":[\"ssh\"]}}"
        step_n=$((step_n + 1))
      fi
      if [ "$should_emit_remote_cmd" -eq 1 ] && [ -n "$cleanup_cmd" ]; then
        sid="scope:${scope}:$(printf '%04d' "$step_n")"
        [ -z "$steps_json" ] || steps_json+="," 
        steps_json+="{\"id\":\"$(json_escape "$sid")\",\"type\":\"remote_cmd\",\"server\":\"$(json_escape "$server")\",\"cmd\":\"$(json_escape "$cleanup_cmd")\",\"label\":\"cleanup\",\"checks\":{\"requires\":[\"ssh\"]}}"
        step_n=$((step_n + 1))
      fi
    done

    if [ "$first_scope" -eq 1 ]; then
      first_scope=0
    else
      plan_json+="," 
    fi

    local workspace_inputs_json=""
    if [ "$workspace_provider" = "git" ]; then
      workspace_inputs_json=",\"workspace_provider\":\"git\",\"repo_url\":\"$(json_escape "$repo_url")\",\"ref\":\"$(json_escape "$ref")\",\"pin\":$([ "$pin" = "false" ] && printf false || printf true),\"commit_sha\":\"$(json_escape "$commit_sha")\",\"workspace_dir\":\"$(json_escape "$source_dir")\""
    fi
    plan_json+="{\"scope\":\"$(json_escape "$scope")\",\"inputs\":{\"source_dir\":\"$(json_escape "$source_dir")\",\"target_dir\":\"$(json_escape "$target_dir")\",\"servers\":${servers_json},\"rsync_opts\":\"$(json_escape "$rsync_opts")\",\"backup\":$([ "$backup" = "true" ] && printf true || printf false),\"backup_suffix\":\"$(json_escape "$backup_suffix")\",\"remote_mkdir\":$([ "$remote_mkdir" = "true" ] && printf true || printf false)${workspace_inputs_json}},\"discovery\":{\"strategy\":\"$(json_escape "$discovery")\",\"since\":${since_json},\"files_found\":${files_found},\"files_selected\":${selected_count}},\"routing\":{\"env_from_filename_prefix\":\"$(json_escape "$routing_filename_prefix")\",\"env_from_server_name_char_at\":$([ -n "$routing_server_char_at" ] && printf '%s' "$routing_server_char_at" || printf null),\"env_from_server_name_char_map\":\"$(json_escape "$routing_server_char_map")\"},\"steps\":[${steps_json}],\"summary\":{\"counts\":{\"mkdir_steps\":${mkdir_steps},\"rsync_steps\":${rsync_steps},\"rollbackable_steps\":${rollbackable_steps},\"warnings\":[]}}}"

    rm -f "$tmp_ref" "$tmp_files" "$tmp_all"
  done < "$scope_list_file"

  plan_json+="],\"analysis\":{\"ai\":{\"enabled\":false,\"provider\":null,\"model\":null,\"generated_at\":null,\"risk\":{\"score\":null,\"level\":null,\"reasons\":[]},\"predicted_failures\":[],\"policy\":{\"advisory_only\":true,\"may_block_deploy\":false,\"requires_human_ack_for_high_risk\":true}}}}"

  if [ "$ci_mode" -ne 1 ]; then
    atomic_write ".seraf/plans/${plan_id}.plan.json" "$plan_json"
  fi

  if [ "$print_stdout" -eq 1 ] || [ "$ci_mode" -eq 1 ]; then
    printf '%s\n' "$plan_json"
  else
    printf '%s\n' "$plan_id"
  fi
}

main() {
  local cmd="${1:-help}"
  case "$cmd" in
    init)
      shift
      init_command "$@"
      ;;
    plan)
      shift
      plan_command "$@"
      ;;
    deploy)
      shift
      deploy_command "$@"
      ;;
    pull)
      shift
      pull_command "$@"
      ;;
    diag)
      shift
      diag_command "$@"
      ;;
    pull-logs)
      shift
      pull_logs_command "$@"
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      err "unknown command: $cmd"
      usage >&2
      return 2
      ;;
  esac
}

main "$@"
